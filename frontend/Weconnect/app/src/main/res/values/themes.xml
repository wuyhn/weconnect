<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Weconnect" parent="Theme.MaterialComponents.DayNight.NoActionBar" />

    <style name="TagCategoryHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#8E8881</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="CustomChipChoice" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:checkable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="chipBackgroundColor">@color/chip_background_state</item>
        <item name="android:textColor">@color/chip_text_state</item>
        <item name="checkedIconVisible">true</item>
        <item name="checkedIcon">@drawable/ic_check</item>
        <item name="checkedIconTint">@android:color/white</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="CustomChipGroupStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="chipSpacingHorizontal">8dp</item>
        <item name="chipSpacingVertical">8dp</item>
        <item name="singleSelection">true</item>
    </style>

    <style name="QuickParticipantChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:checkable">true</item>
        <item name="chipBackgroundColor">@color/chip_background_state</item>
        <item name="android:textColor">@color/chip_text_state</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="ProfileInterestChip" parent="Widget.MaterialComponents.Chip.Entry">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="chipBackgroundColor">@color/chip_background_state</item>
        <item name="android:textColor">@color/chip_text_state</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="closeIconVisible">false</item>
        <item name="checkedIconVisible">false</item>
    </style>
        <dimen name="profile_interest_chip_radius">16dp</dimen>


</resources>