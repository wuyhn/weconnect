<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_beige"
    android:fitsSystemWindows="true">

    <View
        android:id="@+id/viewHandle"
        android:layout_width="45dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#D1CAbF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTagTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/lobster"
        android:text="Tag Interest"
        android:textColor="@color/primary_pink"
        android:textSize="34sp"
        app:layout_constraintTop_toBottomOf="@id/viewHandle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagTitle"
        app:layout_constraintBottom_toTopOf="@id/btnOkInterest">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView style="@style/TagCategoryHeader" android:text="Vận động &amp; Thể thao" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/groupSport"
                style="@style/CustomChipGroupStyle"
                android:clipToPadding="false"
                android:padding="4dp"> <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="⚽ Đá bóng" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="🏸 Cầu lông" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="🏃 Chạy bộ" />
            </com.google.android.material.chip.ChipGroup>

            <TextView style="@style/TagCategoryHeader" android:layout_marginTop="20dp" android:text="Học tập &amp; Công việc" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/groupStudy"
                style="@style/CustomChipGroupStyle"
                android:clipToPadding="false"
                android:padding="4dp">
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="📖 Học bài" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="🇬🇧 Học Tiếng Anh" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="💻 Đồ họa / Code" />
            </com.google.android.material.chip.ChipGroup>

            <TextView style="@style/TagCategoryHeader" android:layout_marginTop="20dp" android:text="Thư giãn &amp; Giải trí" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/groupChill"
                style="@style/CustomChipGroupStyle"
                android:clipToPadding="false"
                android:padding="4dp">
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="☕ Đi Cafe" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="🍿 Xem phim" />
                <com.google.android.material.chip.Chip style="@style/CustomChipChoice" android:text="🎮 Chơi Game" />
            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOkInterest"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:minWidth="160dp"
        android:layout_marginBottom="32dp"
        android:paddingHorizontal="32dp"
        android:text="Xác nhận"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:textStyle="bold"
        app:cornerRadius="27dp"
        app:backgroundTint="@color/primary_pink"
        app:elevation="4dp" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>