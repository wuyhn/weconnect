<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FDFBF7"> <View
    android:layout_width="match_parent"
    android:layout_height="8dp"
    android:background="#EFEBE0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:id="@+id/cvAvatarContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/post_item_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user_placeholder" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/post_item_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:textColor="#111111"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cvAvatarContainer"
                app:layout_constraintEnd_toStartOf="@id/ivPostMenu"
                app:layout_constraintStart_toEndOf="@id/cvAvatarContainer"
                app:layout_constraintTop_toTopOf="@id/cvAvatarContainer"
                tools:text="Tên người dùng" />

            <ImageView
                android:id="@+id/ivPostMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_more"
                android:contentDescription="Menu bài viết"
                app:layout_constraintBottom_toBottomOf="@id/cvAvatarContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/cvAvatarContainer"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/post_item_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#2D3436"
            android:textSize="14sp"
            tools:text="Nội dung bài đăng sẽ hiển thị ở đây..." />

        <androidx.cardview.widget.CardView
            android:id="@+id/post_item_image_container"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/post_item_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user_placeholder" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/post_item_btn_join"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_join"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                tools:text="Tham gia (0/0)" />
            <ImageButton
                android:id="@+id/post_item_btn_view"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_button_secondary"
                android:src="@drawable/ic_see1"
                android:contentDescription="Xem"
                app:tint="#8E8E8E" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>