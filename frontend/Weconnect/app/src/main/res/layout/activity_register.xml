<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F7"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Đăng ký"
                android:textColor="#E91E63"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tham gia cộng đồng WeConnect ngay"
                android:textColor="#455A64"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="30dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="15dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="25dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F5F5F5">
                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="Họ và tên"
                            android:paddingStart="25dp"
                            android:textSize="14sp"
                            android:inputType="textPersonName"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvErrorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E91E63"
                        android:textSize="11sp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#F5F5F5">
                        <EditText
                            android:id="@+id/etBirthday"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="Ngày sinh (DD/MM/YYYY)"
                            android:paddingStart="25dp"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:maxLength="10"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvErrorBirthday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E91E63"
                        android:textSize="11sp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giới tính"
                        android:textColor="#455A64"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="12dp"/>
                    <RadioGroup
                        android:id="@+id/rgGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:gravity="center">
                        <RadioButton android:id="@+id/rbMale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nam" android:buttonTint="#E91E63" android:layout_marginEnd="8dp"/>
                        <RadioButton android:id="@+id/rbFemale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nữ" android:buttonTint="#E91E63" android:layout_marginEnd="8dp"/>
                        <RadioButton android:id="@+id/rbOther" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khác" android:buttonTint="#E91E63"/>
                    </RadioGroup>
                    <TextView
                        android:id="@+id/tvErrorGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E91E63"
                        android:textSize="11sp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="#F5F5F5">
                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="Email"
                            android:paddingStart="25dp"
                            android:textSize="14sp"
                            android:inputType="textEmailAddress"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvErrorEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E91E63"
                        android:textSize="11sp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#F5F5F5">
                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="Mật khẩu"
                            android:paddingStart="25dp"
                            android:textSize="14sp"
                            android:inputType="textPassword"/>
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvErrorPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E91E63"
                        android:textSize="11sp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnRegister"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="30dp"
                        android:text="Đăng Ký"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_premium_gradient"
                        android:textAllCaps="false"
                        app:backgroundTint="@null"
                        android:elevation="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="Đã có tài khoản? Đăng nhập"
                android:textColor="#E91E63"
                android:textStyle="bold"
                android:padding="10dp"/>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>